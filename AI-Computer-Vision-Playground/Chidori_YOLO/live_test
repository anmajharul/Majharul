import cv2
import mediapipe as mp
from ultralytics import YOLO
import os
import time
import random
import numpy as np
import pygame 

# 1. Camera scanner function
def get_available_cameras():
    print("\nScanning cameras... please wait.")
    available_indices = []
    for i in range(5):
        cap = cv2.VideoCapture(i, cv2.CAP_DSHOW)
        if cap.isOpened():
            ret, frame = cap.read()
            if ret:
                available_indices.append(i)
                # Show camera preview for 1 second
                cv2.imshow(f"Camera Preview (Index: {i})", frame)
                cv2.waitKey(1000)
                cv2.destroyAllWindows()
            cap.release()
    return available_indices

def main():
    # Camera selection (terminal input)
    found_cameras = get_available_cameras()
    if not found_cameras:
        print("Error: no camera found.")
        return

    print(f"\nAvailable camera indices: {found_cameras}")
    try:
        chosen_index = int(input("Which camera index do you want to use? "))
        if chosen_index not in found_cameras:
            print("Invalid index! Using the first camera.")
            chosen_index = found_cameras[0]
    except ValueError:
        print("You did not enter a number! Using the first camera.")
        chosen_index = found_cameras[0]

    # 2. Path and audio configuration
    current_file_path = os.path.dirname(os.path.abspath(__file__))
    root_dir = os.path.abspath(os.path.join(current_file_path, "..", ".."))
    model_path = os.path.join(root_dir, "runs", "detect", "naruto_ultimate_v4", "weights", "best.pt")

    if not os.path.exists(model_path):
        print(f"Model not found! Check path: {model_path}")
        return

    # 3. Sound initialization
    pygame.mixer.init()
    sound_path = os.path.join(current_file_path, "chidori.mp3")
    chidori_sound = None
    if os.path.exists(sound_path):
        chidori_sound = pygame.mixer.Sound(sound_path)
        print("Chidori sound loaded!")
    else:
        print(f"Warning: chidori.mp3 not found at {sound_path}. Running without sound.")

    model = YOLO(model_path)
    cap = cv2.VideoCapture(chosen_index, cv2.CAP_DSHOW)  # Open selected camera

    # MediaPipe hand tracking
    mp_hands = mp.solutions.hands
    hands = mp_hands.Hands(max_num_hands=2, min_detection_confidence=0.4)

    jutsu_sequence = []
    last_detected = None
    no_detect_start = 0
    chidori_active = False

    target_sign = "Tatsu -dragon-"

    print(f"\nStarting pro-level Chidori session (Trigger: {target_sign}, Conf: 65%)...")

    while True:
        ret, frame = cap.read()
        if not ret:
            break

        frame = cv2.flip(frame, 1)  # Mirror effect
        h, w, _ = frame.shape
        rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        results_mp = hands.process(rgb_frame)

        annotated_frame = frame.copy()
        current_frame_signs = []

        # 4. Dynamic Auto-Zoom (for recognition at a distance)
        if results_mp.multi_hand_landmarks:
            for hand_landmarks in results_mp.multi_hand_landmarks:
                x_min, y_min, x_max, y_max = w, h, 0, 0
                for lm in hand_landmarks.landmark:
                    x, y = int(lm.x * w), int(lm.y * h)
                    x_min, y_min = min(x_min, x), min(y_min, y)
                    x_max, y_max = max(x_max, x), max(y_max, y)

                # Dynamic padding
                pad_x, pad_y = int((x_max - x_min) * 0.4), int((y_max - y_min) * 0.4)
                x1, y1 = max(0, x_min - pad_x), max(0, y_min - pad_y)
                x2, y2 = min(w, x_max + pad_x), min(h, y_max + pad_y)

                hand_crop = frame[y1:y2, x1:x2]

                if hand_crop.size != 0:
                    results_yolo = model(hand_crop, conf=0.65, show=False)
                    for r in results_yolo:
                        for box in r.boxes:
                            bx1, by1, bx2, by2 = map(int, box.xyxy[0])
                            real_x1, real_y1 = x1 + bx1, y1 + by1
                            real_x2, real_y2 = x1 + bx2, y1 + by2

                            conf = float(box.conf[0])
                            label = model.names[int(box.cls[0])]
                            current_frame_signs.append(label)

                            # Show label with confidence (%)
                            cv2.rectangle(annotated_frame, (real_x1, real_y1), (real_x2, real_y2), (0, 255, 0), 2)
                            text = f"{label} ({conf*100:.1f}%)"
                            (text_w, text_h), _ = cv2.getTextSize(text, cv2.FONT_HERSHEY_SIMPLEX, 0.6, 2)
                            cv2.rectangle(annotated_frame, (real_x1, real_y1 - text_h - 10), (real_x1 + text_w, real_y1), (0, 255, 0), -1)
                            cv2.putText(annotated_frame, text, (real_x1, real_y1 - 5), cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 0, 0), 2)

        # 5. Anti-double count & audio activation logic
        if current_frame_signs:
            detected_now = current_frame_signs[0]
            no_detect_start = 0

            if detected_now == target_sign:
                if not chidori_active:
                    chidori_active = True
                    if chidori_sound:
                        chidori_sound.play()

                if detected_now != last_detected:
                    jutsu_sequence.append(detected_now)
                    last_detected = detected_now
        else:
            if no_detect_start == 0:
                no_detect_start = time.time()
            elif time.time() - no_detect_start > 0.8:
                last_detected = None

        # 6. Realistic cinematic Chidori VFX
        if chidori_active:
            overlay = annotated_frame.copy()

            if results_mp.multi_hand_landmarks:
                for hand_landmarks in results_mp.multi_hand_landmarks:
                    cx = int(hand_landmarks.landmark[0].x * w)
                    cy = int(hand_landmarks.landmark[0].y * h)

                    for _ in range(12):
                        tx, ty = cx + random.randint(-250, 250), cy + random.randint(-250, 250)

                        pts = [(cx, cy)]
                        steps = 5
                        for i in range(1, steps):
                            ix = cx + int((tx - cx) * (i / steps)) + random.randint(-35, 35)
                            iy = cy + int((ty - cy) * (i / steps)) + random.randint(-35, 35)
                            pts.append((ix, iy))
                        pts.append((tx, ty))

                        for i in range(len(pts) - 1):
                            cv2.line(overlay, pts[i], pts[i + 1], (255, 180, 50), random.randint(7, 12))
                            cv2.line(annotated_frame, pts[i], pts[i + 1], (255, 255, 255), random.randint(1, 3))

                    r = random.randint(35, 55)
                    cv2.circle(overlay, (cx, cy), int(r * 1.6), (255, 50, 0), -1)
                    cv2.circle(overlay, (cx, cy), r, (255, 220, 100), -1)
                    cv2.circle(annotated_frame, (cx, cy), int(r * 0.4), (255, 255, 255), -1)

            cv2.addWeighted(overlay, 0.6, annotated_frame, 0.4, 0, annotated_frame)

            cv2.putText(annotated_frame, "!!! CHIDORI !!!", (w // 2 - 140, h // 2),
                        cv2.FONT_HERSHEY_TRIPLEX, 2.0, (255, 255, 255), 5)

            if time.time() - (no_detect_start if no_detect_start else time.time()) > 5:
                chidori_active = False
                jutsu_sequence = []
                if chidori_sound:
                    chidori_sound.stop()

        # Display bar
        display_text = " -> ".join(jutsu_sequence[-5:])
        cv2.rectangle(annotated_frame, (0, 0), (w, 50), (40, 40, 40), -1)
        cv2.putText(annotated_frame, f"Active Sign: {display_text}", (20, 35), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (255, 255, 255), 2)

        cv2.imshow("Naruto Cinematic Jutsu v10.2 (Terminal Cam)", annotated_frame)
        if cv2.waitKey(1) & 0xFF == ord('q'):
            break

    cap.release()
    cv2.destroyAllWindows()

if __name__ == "__main__":
    main()
