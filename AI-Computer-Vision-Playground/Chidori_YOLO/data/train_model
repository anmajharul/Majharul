from ultralytics import YOLO


def main():
    print("YOLOv8 AI Model Training Starting...")

    # 1. Load a pre-trained model (yolov8n.pt is the nano version, fast on CPU/GPU)
    model = YOLO("yolov8n.pt")

    # 2. Train the model with your dataset
    model.train(
        data="data.yaml",
        epochs=50,
        imgsz=640,
        batch=8,
        workers=2,
        name="chidori_model",
    )

    print("Training Complete!")


# Required on Windows to avoid multiprocessing issues
if __name__ == "__main__":
    main()
