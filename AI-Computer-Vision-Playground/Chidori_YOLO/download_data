from roboflow import Roboflow
from ultralytics import YOLO


def main():
    # 1. Download dataset (use your API key)
    rf = Roboflow(api_key="use_your_API_key")
    project = rf.workspace("chayawats-workspace-z7lzz").project("naruto-lkanh")
    version = project.version(1)
    dataset = version.download("yolov8")

    # 2. Load model (YOLOv8 Nano - good for laptops)
    model = YOLO("yolov8n.pt")

    # 3. Train the model
    # Make sure the data.yaml path is correct (usually the folder name is 'naruto-lkanh-1')
    model.train(
        data=f"{dataset.location}/data.yaml",
        epochs=100,
        imgsz=640,
        batch=16,
        name="naruto_ultimate_v4",
        plots=True,
    )


if __name__ == "__main__":
    main()
